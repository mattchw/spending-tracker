# Copy to .env.local for local dev, or set these as environment variables in
# your Vercel project (Settings → Environment Variables) for production.
# NEVER commit real secret values — this file holds placeholders only.

# --- Database (Neon Postgres + Drizzle) --------------------------------------
# Pooled connection string from Neon (Dashboard → Connect → "Pooled connection").
DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# --- TrueLayer (Open Banking) ------------------------------------------------
# "sandbox" (mock bank) or "live" (real banks). Credentials MUST match.
TRUELAYER_ENV=live
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
# How far back to backfill on connect (days). Default 730 (~2 years).
# TRUELAYER_HISTORY_DAYS=730

# Public base URL of the deployment. Add ${APP_BASE_URL}/api/callback as a
# TrueLayer Redirect URI. Locally: http://localhost:3000
APP_BASE_URL=https://your-domain.example

# --- Authentication (Auth.js / NextAuth v5) ----------------------------------
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Token encryption --------------------------------------------------------
# 32-byte key (base64url/base64/hex) for AES-256-GCM encryption of bank tokens.
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
TOKEN_ENC_KEY=

# --- Background sync (Vercel Cron) -------------------------------------------
# Shared secret protecting /api/cron; Vercel Cron sends it as a Bearer token.
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=

# --- Optional one-time data migration ----------------------------------------
# The first time this email signs in, pre-login data is claimed for the account.
# LEGACY_OWNER_EMAIL=you@example.com
