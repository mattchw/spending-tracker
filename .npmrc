# Always resolve from the public npm registry. Without this, an internal/work
# registry from a user-level ~/.npmrc leaks into package-lock.json "resolved"
# URLs, which Vercel's build servers can't reach (install then crashes with
# "Exit handler never called!").
registry=https://registry.npmjs.org/

# Workaround for npm "Exit handler never called!" during install on CI/Vercel.
# npm/agent-base strands queued tarball fetches when the dependency count exceeds
# `maxsockets` (default 15) and any fetch hiccups (npm/cli#9386). Raising the socket
# ceiling avoids queuing, and retries recover from transient registry blips.
maxsockets=64
fetch-retries=5
fetch-retry-mintimeout=2000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
